{
  "name": "wordmaster-monorepo",
  "version": "1.0.0",
  "description": "WordMaster - Language Learning Platform (Monorepo)",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "admin",
    "shared"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev:mobile": "cd mobile && npx expo start",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=admin && npm install --workspace=mobile",
    "clean": "rm -rf node_modules backend/node_modules admin/node_modules mobile/node_modules",
    "test:all": "npm run test --workspaces --if-present"
  },
  "keywords": [
    "language-learning",
    "vocabulary",
    "spaced-repetition",
    "react-native",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
